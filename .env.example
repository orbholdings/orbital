# Copy to ".env" for local dev, or set these in Coolify → App → Environment.

PORT=4173

# ---- Supabase (REQUIRED) ------------------------------------------------
# From Supabase: Project Settings → API.
# URL + anon key are public; the service role key is SECRET (server only).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Secret used to encrypt users' provider keys at rest (AES-256-GCM).
# Use a long random string. If unset, the service-role key is used as a fallback.
ORBITAL_SECRET=

# ---- LLM providers (optional — app runs in demo mode without them) ------
# OpenRouter = one key for Claude, GPT, Gemini, GLM, Kimi and many more.
OPENROUTER_API_KEY=

# Local models via Ollama (no key). If Ollama runs on the host, point here.
OLLAMA_BASE_URL=http://localhost:11434

# Direct provider keys (only if you skip OpenRouter)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
ZHIPU_API_KEY=
MOONSHOT_API_KEY=
XAI_API_KEY=
# Note: users can also add any of these (and custom OpenAI-compatible providers)
# from the in-app Settings page — no server env vars required.
